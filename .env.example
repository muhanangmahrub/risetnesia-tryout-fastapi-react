# ============================================================
# Copy to .env and fill in your actual values.
# NEVER commit .env to version control!
# ============================================================

# Database
DB_SERVER=SQL_Server_Docker
DB_USER=sa
DB_PASSWORD=YourStrongPassword123!
DB_NAME=tryout_db

# Backend
DATABASE_URL=mssql+pyodbc://sa:YourStrongPassword123!@SQL_Server_Docker:1433/tryout_db?driver=ODBC+Driver+17+for+SQL+Server
JWT_SECRET=replace_this_with_a_very_long_random_secret_key

# Frontend (Vite)
VITE_API_URL=http://localhost:8000/api/v1
